{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "web/**", "use": "@vercel/static" }
  ],
  "regions": ["sin1"],
  "functions": {
    "api/cron/collect.js": {
      "maxDuration": 60,
      "regions": ["sin1"]
    },
    "api/data.csv.js": {
      "maxDuration": 30,
      "regions": ["sin1"]
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/data\\.csv", "dest": "/api/data.csv.js" },
    { "src": "/api/cron/collect", "dest": "/api/cron/collect.js" },
    { "src": "/(?!api/)(.*)", "dest": "/web/$1" }
  ]
}
